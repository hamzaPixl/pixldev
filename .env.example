# Pixl Environment Variables

# Google Analytics 4 Measurement ID
# Get this from Google Analytics > Admin > Data Streams > Web
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Search engine verification tokens (optional — injected into metadata when set)
# Google Search Console > Settings > Ownership verification > HTML tag
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools > Settings > Verification > Meta tag
NEXT_PUBLIC_BING_SITE_VERIFICATION=
